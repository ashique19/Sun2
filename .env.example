APP_NAME=Sundoritoma
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=bn
APP_STOREFRONT_LOCALE=bn
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sun2
DB_USERNAME=root
DB_PASSWORD=

DB_LEGACY_DATABASE=sun_legacy
DB_LEGACY_USERNAME=root
DB_LEGACY_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Checkout
CHECKOUT_DHAKA_CITY_UPTO_5=80
CHECKOUT_DHAKA_CITY_OVER_5=150
CHECKOUT_OUTSIDE_UPTO_5=120
CHECKOUT_OUTSIDE_OVER_5=200
CHECKOUT_OTP_TTL=10

# Steadfast Courier (order dispatch + webhooks)
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=
STEADFAST_BASE_URL=https://portal.packzy.com/api/v1
STEADFAST_TIMEOUT=30
STEADFAST_WEBHOOK_ENABLED=true
STEADFAST_WEBHOOK_TOKEN=
# Callback URL for Steadfast portal: {APP_URL}/api/steadfast/webhook

# Optional: hosting panel cron can hit /internal/sitemap/rebuild?token=...
SITEMAP_REBUILD_TOKEN=

# Optional: hosting panel cron can hit /internal/product-image-hashes/rebuild?token=...
PRODUCT_IMAGE_HASH_REBUILD_TOKEN=
PRODUCT_IMAGE_HASH_CHUNK_SIZE=25

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Pathao Courier API
PATHAO_ENABLED=false
PATHAO_ENVIRONMENT=sandbox
PATHAO_BASE_URL=https://courier-api-sandbox.pathao.com
PATHAO_CLIENT_ID=
PATHAO_CLIENT_SECRET=
PATHAO_USERNAME=
PATHAO_PASSWORD=
PATHAO_STORE_ID=
PATHAO_DELIVERY_TYPE=48
PATHAO_ITEM_TYPE=2
PATHAO_DEFAULT_WEIGHT=0.5
PATHAO_WEBHOOK_ENABLED=true
PATHAO_WEBHOOK_SECRET=
PATHAO_WEBHOOK_INTEGRATION_SECRET=
# Callback URL: {APP_URL}/api/webhooks/pathao

# RedX Courier API
REDX_ENABLED=false
REDX_BASE_URL=https://openapi.redx.com.bd/v1.0.0-beta
REDX_API_TOKEN=
REDX_PICKUP_STORE_ID=
REDX_DEFAULT_WEIGHT=1
REDX_WEBHOOK_ENABLED=true
REDX_WEBHOOK_TOKEN=
# Callback URL: {APP_URL}/api/webhooks/redx?token={REDX_WEBHOOK_TOKEN}

# CarryBee Courier API
CARRYBEE_ENABLED=false
CARRYBEE_ENVIRONMENT=sandbox
CARRYBEE_BASE_URL=https://stage-sandbox.carrybee.com
CARRYBEE_CLIENT_ID=
CARRYBEE_CLIENT_SECRET=
CARRYBEE_CLIENT_CONTEXT=
CARRYBEE_STORE_ID=
CARRYBEE_DELIVERY_TYPE=1
CARRYBEE_PRODUCT_TYPE=1
CARRYBEE_DEFAULT_WEIGHT_GRAMS=500
CARRYBEE_WEBHOOK_ENABLED=true
CARRYBEE_WEBHOOK_SECRET=
# Callback URL: {APP_URL}/api/webhooks/carrybee

# Facebook Messenger (Page inbox webhook)
FACEBOOK_MESSENGER_WEBHOOK_ENABLED=true
# Pick any long random string; paste the SAME value into Meta's "Verify token" field.
FACEBOOK_MESSENGER_VERIFY_TOKEN=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_GRAPH_VERSION=v25.0
# Callback URL for Meta: {APP_URL}/api/webhooks/messenger

# WhatsApp Cloud API webhook
WHATSAPP_WEBHOOK_ENABLED=true
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_GRAPH_VERSION=v25.0
# Callback URL for Meta: {APP_URL}/api/webhooks/whatsapp

# SMS (log driver writes OTP to storage/logs/laravel.log in local dev)
SMS_DRIVER=log
SMS_FROM=Sundoritoma
SMS_SSL_WIRELESS_URL=https://smsplus.sslwireless.com/api/v3/send-sms
SMS_SSL_WIRELESS_TOKEN=
SMS_SSL_WIRELESS_SID=
